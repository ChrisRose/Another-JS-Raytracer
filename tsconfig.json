{
  "compilerOptions": {
    "target": "ES2022",
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "strict": true,
    "skipLibCheck": true,
    "outDir": "src/public",
    "module": "ES2022",
    "moduleResolution": "node",
    "types": ["vite/client"]
  },
  "exclude": ["src/**/*.spec.ts", "*.config.ts", "generate-thumbnails.mts"]
}
